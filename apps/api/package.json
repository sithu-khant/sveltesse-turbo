{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:dev": "wrangler deploy --env dev --minify",
    "deploy:prod": "wrangler deploy --env prod --minify",
    "secret:bulk:dev": "wrangler --env dev secret bulk .env.local",
    "secret:bulk:prod": "wrangler --env prod secret bulk .env.prod",
    "gen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "@scalar/hono-api-reference": "^0.10.7",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^12.0.3",
    "hono": "^4.12.12",
    "hono-pino": "^0.10.3",
    "stoker": "^2.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "wrangler": "^4.4.0"
  }
}
