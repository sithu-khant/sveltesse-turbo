{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "compatibility_date": "2026-04-14",
  "compatibility_flags": [
    "nodejs_als",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "placement": {
    "mode": "smart"
  },
  "env": {
    "dev": {
      "name": "sveltesse-turbo-dev",
      "workers_dev": true,
      "services": [
        {
          "binding": "API",
          "service": "sveltesse-turbo-api-dev"
        }
      ]
    },
    "prod": {
      "name": "sveltesse-turbo-prod",
      "route": "sveltesse-turbo.com",
      "workers_dev": false
    }
  }
}
