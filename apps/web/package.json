{
  "name": "@repo/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "pnpm run build && wrangler dev",
    "deploy:dev": "pnpm run build && wrangler --env dev deploy",
    "deploy:prod": "pnpm run build --mode prod && wrangler --env prod deploy",
    "secret:bulk:dev": "wrangler --env dev secret bulk .env.local",
    "secret:bulk:prod": "wrangler --env prod secret bulk .env.prod",
    "check-types": "tsc --noEmit",
    "doctor:check": "pnpm dlx svelte-doctor check",
    "check": "pnpm dlx svelte-check-rs",
    "check:watch": "pnpm dlx svelte-check-rs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "gen": "wrangler types"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.8.0",
    "@repo/api-type": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/table-core": "^8.21.3",
    "@types/node": "^24.12.0",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-svelte": "^3.16.0",
    "mode-watcher": "^1.1.0",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.54.1",
    "svelte-check": "^4.4.5",
    "svelte-eslint-parser": "^1.6.0",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "wrangler": "^4.82.2"
  },
  "dependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "hono": "^4.12.12"
  }
}
